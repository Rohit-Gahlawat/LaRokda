generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String                @id @default(uuid())
  email               String?               @unique
  name                String?
  number              String                @unique
  password            String
  Balance             Balance[]
  onRampTransaction   OnRampTransaction[]
  sendTransaction     P2P[]                 @relation(name: "fromUserRelation")
  receivedTransaction P2P[]                 @relation(name: "toUserRelation")
  merchantTransaction MerchantTransaction[]
  userWthdrawal       UserWithdrawal[]
}

model Merchant {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  name                String?
  auth_type           AuthType
  merchantBalance     MerchantBalance[]
  merchantTransaction MerchantTransaction[]
  merchantWithdrawal  MerchantWithdrawal[]
}

model MerchantBalance {
  id         Int      @id @default(autoincrement())
  merchantId Int      @unique
  amount     Int      @default(0)
  locked     Int      @default(0)
  merchant   Merchant @relation(fields: [merchantId], references: [id])
}

model Balance {
  id     Int    @id @default(autoincrement())
  userId String @unique
  amount Int    @default(0)
  locked Int    @default(0)
  user   User   @relation(fields: [userId], references: [id])
}

model MerchantTransaction {
  id         Int      @id @default(autoincrement())
  amount     Int
  timestamp  DateTime
  fromUserId String
  fromUser   User     @relation(fields: [fromUserId], references: [id])
  toUserId   Int
  toUser     Merchant @relation(fields: [toUserId], references: [id])
}

model OnRampTransaction {
  id        Int              @id @default(autoincrement())
  status    OnRampStatusType
  token     String           @unique
  provider  String
  amount    Int
  startTime DateTime
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

model P2P {
  id         Int      @id @default(autoincrement())
  amount     Int
  timestamp  DateTime
  fromUserId String
  fromUser   User     @relation(name: "fromUserRelation", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation(name: "toUserRelation", fields: [toUserId], references: [id])
}

model UserWithdrawal {
  id        Int                @id @default(autoincrement())
  amount    Int
  status    UserWithdrawalEnum
  provider  String
  token     String             @unique
  startTime DateTime
  userId    String
  user      User               @relation(fields: [userId], references: [id])
}

model MerchantWithdrawal {
  id        Int                @id @default(autoincrement())
  amount    Int
  status    UserWithdrawalEnum
  provider  String
  token     String             @unique
  startTime DateTime
  userId    Int
  merchant  Merchant           @relation(fields: [userId], references: [id])
}

enum AuthType {
  google
  github
}

enum OnRampStatusType {
  Success
  Failed
  Processing
}

enum UserWithdrawalEnum {
  Success
  Failed
  Processing
}
